bench/data/

# Eval run-logs (replayable from scripts; results JSONs are committed)
eval/results/runlog/
eval/results/_smoke_*.json
# regeneratable raw copy made for re-judging (cp of verify-before-completion.json);
# the small .ollama.judged.json result IS committed
eval/results/verify-before-completion.ollama.json

# semdiff session cache
.cache/semdiff/

# DeepEval telemetry/cache (created by eval/exp2_retrieval runs)
.deepeval/
.deepeval_telemetry.txt
eval/*/output/

# Token Economy runtime state
.token-economy/
.token-economy-profile
