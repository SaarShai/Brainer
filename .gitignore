# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.venv/
.venvs/
venv/

# graphify build outputs (regeneratable; not committed)
graphify-out/

# Benchmark data (large, fetched via scripts)
bench/data/

# Eval run-logs (replayable from scripts; results JSONs are committed)
eval/results/runlog/
eval/results/_smoke_*.json
# regeneratable raw copy made for re-judging (cp of verify-before-completion.json);
# the small .ollama.judged.json result IS committed
eval/results/verify-before-completion.ollama.json

# semdiff session cache
.cache/semdiff/

# DeepEval telemetry/cache (created by eval/exp2_retrieval runs)
.deepeval/
.deepeval_telemetry.txt
eval/*/output/

# Brainer runtime state
.brainer/
.brainer-profile
.claude/
.mcp.json

# Per-machine install targets (./install.sh symlinks skills into these)
.codex/skills/
.cursor/skills/
.cursor/rules/
.gemini/skills/

# cache-lint per-project fingerprint baseline
.cache-lint-fingerprint.json

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Long-run per-rep dumps + logs (the longrun_<node>.jsonl summary IS committed)
eval/longrun/results/drift_*.json
eval/longrun/results/compound_*.json
eval/longrun/results/*.log
# Re-judge candidate copies (regeneratable cp of verify-before-completion.ollama.json);
# the small .judged.json delta results ARE committed
eval/results/verify_rejudge_*.json
!eval/results/verify_rejudge_*.judged.json
scratch/

# eval/sims/* outputs are offline-regenerable (python3 eval/sims/run_all.py) and
# carry per-run timing (ms/headroom/throughput) → committing them churns every
# suite run. Same policy as the runlog/longrun dumps above: regenerate, don't track.
# (The A/B task results under eval/results/ stay committed — they need a model run.)
eval/sims/results/

# wiki-refresh staleness marker (per-checkout HEAD hash; local-only)
wiki/.refresh-state.json
