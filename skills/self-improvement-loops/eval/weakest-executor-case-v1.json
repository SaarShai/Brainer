{
  "schema_version": 2,
  "case_id": "incident-chronology-control-plane-transfer-v2",
  "independence": {
    "not_used_to_author_policy": true,
    "domain_shift": "incident-summary chronology rather than prompt benchmark accuracy",
    "surface_shift": "quality scorer, incident archive, permissions, and runtime controls",
