{
  "$schema": "https://claude.com/schemas/plugin-marketplace.json",
  "name": "token-economy",
  "version": "1.3.0",
  "description": "Token/context-efficient skills for AI coding agents. 11 skills covering output style, planning, lean execution, verification, wiki memory, unified handoff, prompt triage, PreCompact extraction, compound compression, semantic AST diff, and output filtering. 10 of 11 measured live; mean per-call savings range -20% to -98% depending on skill type.",
  "homepage": "https://github.com/SaarShai/token-economy",
  "license": "MIT",
  "author": "Saar Shai",
  "plugins": [
    {
      "name": "token-economy",
      "version": "1.3.0",
      "description": "All 11 skills bundled.",
      "source": {
        "type": "git-subdirectory",
        "directory": "skills/"
      },
      "context_cost_estimate_tokens": 1100,
      "skills": [
        "caveman-ultra",
        "plan-first-execute",
        "lean-execution",
        "verify-before-completion",
        "wiki-memory",
        "handoff",
        "prompt-triage",
        "context-keeper",
        "compress-context",
        "semantic-diff",
        "output-filter"
      ],
      "hooks": [
        {
          "event": "UserPromptSubmit",
          "command": "bash ${PLUGIN_DIR}/skills/prompt-triage/tools/hook.sh",
          "matcher": "*",
          "optional": true,
          "description": "prompt-triage classifier; opt-in via plugin config."
        },
        {
          "event": "PreCompact",
          "command": "bash ${PLUGIN_DIR}/skills/context-keeper/tools/hook.sh",
          "matcher": "*",
          "optional": true,
          "description": "context-keeper structured-state extraction."
        }
      ]
    }
  ]
}
