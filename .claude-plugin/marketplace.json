{
  "$schema": "https://claude.com/schemas/plugin-marketplace.json",
  "name": "token-economy",
  "version": "1.0.0",
  "description": "Token/context-efficient skills for AI coding agents. 15 skills covering output style, planning, lean execution, verification, wiki memory, context refresh + relay, prompt triage, delegation, PreCompact extraction, tier-aware memory API, compound compression, semantic AST diff, output filtering, and a skill-creator helper.",
  "homepage": "https://github.com/saarshai/token-economy",
  "license": "MIT",
  "author": "Saar Shai",
  "plugins": [
    {
      "name": "token-economy",
      "version": "1.0.0",
      "description": "All 15 skills bundled.",
      "source": {
        "type": "git-subdirectory",
        "directory": "skills/"
      },
      "context_cost_estimate_tokens": 4800,
      "skills": [
        "caveman-ultra",
        "plan-first-execute",
        "lean-execution",
        "verify-before-completion",
        "wiki-memory",
        "context-refresh",
        "prompt-triage",
        "personal-assistant",
        "delegate",
        "context-keeper",
        "memory-api",
        "compress-context",
        "semantic-diff",
        "output-filter",
        "skill-creator"
      ],
      "hooks": [
        {
          "event": "UserPromptSubmit",
          "command": "bash ${PLUGIN_DIR}/skills/prompt-triage/tools/hook.sh",
          "matcher": "*",
          "optional": true,
          "description": "prompt-triage classifier; opt-in via plugin config."
        },
        {
          "event": "PreCompact",
          "command": "bash ${PLUGIN_DIR}/skills/context-keeper/tools/hook.sh",
          "matcher": "*",
          "optional": true,
          "description": "context-keeper structured-state extraction."
        }
      ]
    }
  ]
}
