{
  "hooks": {
    "BeforeAgent": [
      {
        "hooks": [
          {
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$PWD}/.gemini/skills/compliance-canary/tools/hook.sh\"",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PreCompress": [
      {
        "hooks": [
          {
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$PWD}/.gemini/skills/context-keeper/tools/hook.sh\"",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$PWD}/.gemini/skills/context-keeper/tools/archive.sh\"",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "skills": {
    "dirs": [
      ".gemini/skills"
    ]
  }
}
