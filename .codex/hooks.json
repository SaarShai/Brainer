{
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bash ./.claude/skills/context-keeper/tools/hook.sh",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "bash ./.claude/skills/context-keeper/tools/codex_archive.sh",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "bash ./.codex/skills/learn-skill/tools/hook_codex_stop.sh",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bash ./.claude/skills/prompt-triage/tools/hook.sh",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "bash ./.codex/skills/learn-skill/tools/hook_session_start.sh",
            "type": "command"
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "command": "bash ./.codex/skills/compliance-canary/tools/hook.sh",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  }
}
